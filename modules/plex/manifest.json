{
  "id": "com.240mp.plex",
  "name": "Plex",
  "icon": "assets/images/logo.svg",
  "entry_point_qml": "views/Root.qml",
  "settings": [
    {
      "key": "enabled",
      "label": "Enabled",
      "type": "toggle",
      "default": "OFF"
    },
    {
      "key": "current_user_id",
      "label": "Current User",
      "type": "list_single",
      "options_source": "dynamic",
      "options_slot": "getUsers",
      "apply_slot": "applyCurrentUserSetting",
      "requires_auth": true
    },
    {
      "key": "auto_sign_in",
      "label": "Auto Sign In",
      "type": "toggle",
      "default": "OFF",
      "requires_auth": true
    },
    {
      "key": "server_machine_id",
      "label": "Server",
      "type": "list_single",
      "options_source": "dynamic",
      "options_slot": "getServers",
      "apply_slot": "applyCurrentServerSetting",
      "requires_auth": true
    },
    {
      "key": "libraries",
      "label": "Libraries",
      "type": "multiselect_submenu",
      "options_source": "dynamic",
      "options_slot": "getLibraries",
      "requires_auth": true
    },
    {
      "key": "library_order",
      "label": "Reorder Sources",
      "type": "reorder_submenu",
      "options_source": "dynamic",
      "options_slot": "getLibraries",
      "options_key": "libraries",
      "requires_auth": true,
      "description": "Set the order libraries appear in on Home and in the library list. Select a library to pick it up, then move it with up/down."
    },
    {
      "key": "video_quality",
      "label": "Video Quality",
      "type": "list_single",
      "options_source": "dynamic",
      "options_slot": "getVideoQualities",
      "requires_auth": true
    },
    {
      "key": "resume_playback",
      "label": "Resume Playback",
      "type": "list_single",
      "options_source": "dynamic",
      "options_slot": "get_resume_playback_options",
      "default": "ask",
      "requires_auth": true
    },
    {
      "key": "browse_view",
      "label": "Browse View",
      "type": "list_single",
      "options": ["Title", "Cover"],
      "default": "Title"
    },
    {
      "key": "info_background",
      "label": "Fanart Background",
      "type": "toggle",
      "default": "ON"
    },
    {
      "key": "info_background_opacity",
      "label": "Background Opacity",
      "type": "list_single",
      "options": ["10%", "20%", "30%", "40%", "60%"],
      "default": "30%"
    },
    {
      "key": "autoplay_next_episode",
      "label": "Autoplay Next Episode",
      "type": "toggle",
      "default": "OFF",
      "requires_auth": true
    },
    {
      "key": "intro_skip",
      "label": "Skip Intro",
      "type": "list_single",
      "options": ["Off", "Auto", "Button"],
      "default": "Off",
      "requires_auth": true,
      "description": "Show a Skip Intro button (or auto-skip) using the server's intro markers. Requires Plex's intro detection to have run for the show."
    },
    {
      "key": "show_themes",
      "label": "Show Theme Music",
      "type": "toggle",
      "default": "OFF",
      "requires_auth": true,
      "description": "Play a show's theme song while its info screen is open (for shows that have one)."
    },
    {
      "key": "theme_volume",
      "label": "Theme Volume",
      "type": "list_single",
      "options": ["25%", "50%", "75%", "100%"],
      "default": "50%",
      "requires_auth": true
    },
    {
      "key": "show_related",
      "label": "More Like This",
      "type": "toggle",
      "default": "ON",
      "requires_auth": true,
      "description": "Show a related-titles row on the info screen, revealed when you move down to the audio/subtitle rows."
    },
    {
      "key": "logout",
      "label": "Sign out",
      "type": "action",
      "action_slot": "logout",
      "requires_auth": true
    }
  ]
}
